{
    "name": "Koma-Nezha",
    "short": "Koma-Nezha",
    "description": "Koma-Nezha Theme for Komari Monitor",
    "version": "1.1.4",
    "author": "BITJEBE",
    "url": "https://github.com/yutian81/koma-nezha",
    "preview": "preview.png",
    "configuration": {
        "type": "managed",
        "data": [
            {
                "name": "外观设置",
                "type": "title"
            },
            {
                "key": "CustomBackgroundImage",
                "name": "背景图片",
                "type": "input",
                "default": "",
                "help": "桌面端背景图片URL，留空则不显示背景图。支持图片直链或随机图API。"
            },
            {
                "key": "CustomMobileBackgroundImage",
                "name": "移动端背景图片",
                "type": "input",
                "default": "",
                "help": "移动端单独的背景图片URL，留空则跟随桌面端设置。"
            },
            {
                "key": "CustomLogo",
                "name": "站点Logo",
                "type": "input",
                "default": "/favicon.ico",
                "help": "站点Logo图片URL，显示在左上角和浏览器标签页。"
            },
            {
                "key": "CustomIllustration",
                "name": "自定义插图",
                "type": "input",
                "default": "",
                "help": "首页右侧的自定义插图URL，留空使用默认插图。"
            },
            {
                "key": "ForceTheme",
                "name": "强制主题",
                "type": "select",
                "options": "跟随系统,dark,light",
                "default": "跟随系统",
                "help": "强制使用指定主题模式，选择'跟随系统'则由用户自行切换。"
            },
            {
                "name": "功能设置",
                "type": "title"
            },
            {
                "key": "CustomLinks",
                "name": "自定义链接",
                "type": "input",
                "default": "",
                "help": "JSON格式的自定义链接数组，显示在顶部导航栏。格式: [{\"link\":\"https://example.com\",\"name\":\"示例\"}]"
            },
            {
                "key": "ForceShowServices",
                "name": "显示服务监控",
                "type": "switch",
                "default": false,
                "help": "开启后在首页显示ServiceTracker服务监控面板（30天可用性监控）。"
            },
            {
                "key": "ForceShowMap",
                "name": "显示全球地图",
                "type": "switch",
                "default": false,
                "help": "开启后在首页显示服务器全球分布地图。"
            },
            {
                "key": "ForceCardInline",
                "name": "行内卡片模式",
                "type": "switch",
                "default": false,
                "help": "开启后服务器卡片使用紧凑的行内布局模式。"
            },
            {
                "key": "DisableAnimatedMan",
                "name": "禁用动画插图",
                "type": "switch",
                "default": true,
                "help": "开启后隐藏首页的动画人物插图。默认已开启（隐藏）。"
            },
            {
                "key": "ForceUseSvgFlag",
                "name": "使用SVG国旗",
                "type": "switch",
                "default": false,
                "help": "开启后使用SVG国旗图标替代Emoji国旗，在部分系统上显示效果更好。"
            },
            {
                "key": "ShowTrafficBar",
                "name": "显示流量进度条",
                "type": "switch",
                "default": true,
                "help": "开启后在服务器卡片上显示流量使用进度条（需后台配置流量限额）。"
            },
            {
                "key": "ShowVisitorCapsule",
                "name": "显示访客胶囊",
                "type": "switch",
                "default": false,
                "help": "开启后在页面底部短暂显示访客 IP、地区和运营商信息。"
            },
            {
                "key": "VisitorCapsuleColor",
                "name": "访客胶囊颜色",
                "type": "select",
                "options": "blue,green,purple,pink,orange,red,cyan,amber",
                "default": "blue",
                "help": "访客胶囊的主色调，亮/暗模式自动配套。"
            },
            {
                "key": "ShowAssetCard",
                "name": "显示资产卡片",
                "type": "switch",
                "default": false,
                "help": "开启后显示右上角资产统计浮窗，账单金额会使用默认货币和服务器货币覆盖配置。"
            },
            {
                "key": "AssetCardColor",
                "name": "资产卡片颜色",
                "type": "select",
                "options": "blue,green,purple,pink,orange,red,cyan,amber",
                "default": "blue",
                "help": "资产卡片浮窗的主色调，亮/暗模式自动配套。"
            },
            {
                "key": "AssetCardDefaultCurrency",
                "name": "资产卡片默认币种",
                "type": "select",
                "options": "CNY,USD,HKD,EUR,GBP,JPY",
                "default": "CNY",
                "help": "资产卡片汇总金额的默认显示币种，访客仍可在资产卡片内临时切换。"
            },
            {
                "key": "ForcePeakCutEnabled",
                "name": "网络图表削峰",
                "type": "switch",
                "default": false,
                "help": "开启后网络流量图表会自动裁剪异常峰值，使图表更易读。"
            },
            {
                "name": "卡片显示设置",
                "type": "title"
            },
            {
                "key": "FixedTopServerName",
                "name": "固定顶部服务器名称",
                "type": "switch",
                "default": false,
                "help": "开启后服务器名称固定在卡片顶部，资源信息显示在下方。"
            },
            {
                "key": "ShowNetTransfer",
                "name": "显示上下行流量",
                "type": "switch",
                "default": false,
                "help": "开启后在服务器卡片底部显示上传和下载总流量。"
            },
            {
                "key": "HideIPv4IPv6Tag",
                "name": "隐藏IPv4/IPv6标签",
                "type": "switch",
                "default": false,
                "help": "开启后隐藏服务器卡片上默认显示的IPv4和IPv6标签。"
            },
            {
                "key": "HideTrafficVolTag",
                "name": "隐藏流量标签",
                "type": "switch",
                "default": false,
                "help": "开启后隐藏服务器卡片上显示的流量标签。"
            },
            {
                "name": "账单货币设置",
                "type": "title"
            },
            {
                "key": "DefaultBillingCurrency",
                "name": "默认账单货币",
                "type": "select",
                "options": "跟随后端,CNY,JPY,USD,EUR,HKD,TWD,KRW,SGD,CAD,AUD",
                "default": "跟随后端",
                "help": "没有单独覆盖时使用的货币。选择跟随后端时使用 Komari 节点的 currency 字段；后端填裸 ¥/￥ 时按 CNY 识别，日元建议填 JPY、JP¥ 或单独覆盖。"
            },
            {
                "key": "CnySymbolStyle",
                "name": "人民币显示风格",
                "type": "select",
                "options": "¥,CNY",
                "default": "¥",
                "help": "人民币金额前缀。¥ 视觉简洁，适合部署里大部分是人民币、少数是日元的场景（日元会自动加 JPY 文字消歧义）。日元为主的部署可切到 CNY 文字。"
            },
            {
                "key": "ServerBillingCurrencyOverrides",
                "name": "服务器货币覆盖",
                "type": "input",
                "default": "",
                "help": "JSON对象，按服务器UUID、卡片ID或名称指定货币，例如 {\"Tokyo\":\"JPY\",\"spartanhost\":\"USD\"}。【更推荐】直接在 Komari 后端服务器的 tags 字段里加 <JPY>/<USD>/<CNY> 等元标签，例如把 KDDI 的 tags 改成 \"Tokyonline; KDDI; <JPY>\"，主题会自动识别且不在前端显示该标签。优先级：本JSON > tags元标签 > 默认账单货币 > 后端currency字段。"
            },
            {
                "name": "流量进度条设置",
                "type": "title"
            },
            {
                "key": "TrafficBarShowPercent",
                "name": "显示百分比",
                "type": "switch",
                "default": true,
                "help": "在流量进度条右上角显示已用百分比。"
            },
            {
                "key": "TrafficBarShowResetDay",
                "name": "显示流量重置日",
                "type": "switch",
                "default": true,
                "help": "在流量进度条右上角显示距离流量重置的天数。"
            },
            {
                "key": "TrafficBarShowBillingMode",
                "name": "显示计费模式",
                "type": "switch",
                "default": true,
                "help": "在流量进度条右上角显示计费模式（双向/单向等）。"
            }
        ]
    }
}
